# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=bluteksbot
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
LOG_DEBUG_DEPENDENCIES=
LOG_FILE=logs/bluteksbot.log
ENVIRONMENT=development # development | production

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                   # Required: BotFather token
TELEGRAM_POLLING_INTERVAL=1           # seconds between polls
TELEGRAM_TIMEOUT=30                   # long-poll timeout in seconds
TELEGRAM_ALLOWED_USER_IDS=            # comma-separated Telegram user IDs (empty = allow all)

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/?directConnection=true   # use mongodb://mongo:27017/?directConnection=true inside Docker
MONGO_DB=bluteksbot
MONGO_COLLECTION_EVENTS=events
MONGO_COLLECTION_MEMORY=memory
MONGO_COLLECTION_DLQ=dlq
MONGO_COLLECTION_IDEMPOTENCY=processed

# ── LLM provider keys (forwarded to LiteLLM proxy — not called directly) ─────
OPENAI_API_KEY=                       # Required: GPT-5.x models
ANTHROPIC_API_KEY=                    # Required: Claude Opus/Sonnet models
MINIMAX_API_KEY=                      # Required: MiniMax M2 models

# ── LiteLLM (self-hosted proxy) ───────────────────────────────────────────────
LITELLM_BASE_URL=http://localhost:4000              # use http://litellm:4000 inside Docker
LITELLM_API_KEY=sk-dummy              # proxy master key
LITELLM_ORCHESTRATOR_MODEL=claude-sonnet-4-5
LITELLM_WORKER_MODEL=minimax-m2
LITELLM_MAX_TOKENS=4096
LITELLM_TEMPERATURE=0.2

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_DIMENSION=1536
MEMORY_TOP_K=5

# ── Tools: Web Search ─────────────────────────────────────────────────────────
TAVILY_API_KEY=                       # Required for web search
WEB_SEARCH_MAX_RESULTS=5

# ── Tools: Email / SMTP ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# ── Tools: Calendar ───────────────────────────────────────────────────────────
CALENDAR_TIMEZONE=UTC

# ── Tools: Code Execution ─────────────────────────────────────────────────────
CODE_EXECUTOR_TIMEOUT=60              # seconds; hard kill after this (use higher for tool installs)
CODE_EXECUTOR_MAX_OUTPUT_CHARS=5000   # truncate stdout+stderr beyond this length

# ── LangGraph / Deep Agents ───────────────────────────────────────────────────
DEEP_AGENT_WORKSPACE=/workspace/agent_files  # persistent filesystem root for agent-generated files (code execution + agent writes)

# ── Exponential Backoff ───────────────────────────────────────────────────────
BACKOFF_BASE_SECONDS=1.0
BACKOFF_MAX_SECONDS=60.0
BACKOFF_MULTIPLIER=2.0

# ── LangGraph / Deep Agents / LangMem ────────────────────────────────────────
LANGMEM_NAMESPACE=bluteksbot,memories   # comma-separated namespace parts for long-term memory

# ── Dashboard (observability UI) ─────────────────────────────────────────────
DASHBOARD_PORT=8080
DASHBOARD_ENABLED=true

# ── LangSmith (optional — set LANGSMITH_TRACING=true to enable) ──────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=bluteksbot

# ── Summarization ─────────────────────────────────────────────────────────────
SUMMARIZATION_TRIGGER_TOKENS=100000